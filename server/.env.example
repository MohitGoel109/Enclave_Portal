# Server port (Render sets PORT automatically, this is the local fallback)
PORT=8888

# MongoDB connection string (MongoDB Atlas recommended for production)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/enclave-portal

# Comma-separated list of allowed origins for CORS (your Vercel domain)
CORS_ORIGIN=https://your-app.vercel.app

# Environment
NODE_ENV=production

# Optional rate limit overrides
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=5
